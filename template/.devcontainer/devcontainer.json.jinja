{
  "name": "{{ project_name }}",
  "image": "{% if language == 'python' %}mcr.microsoft.com/devcontainers/python:1-3.12-bookworm{% elif language == 'nodejs' %}mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm{% elif language == 'rust' %}mcr.microsoft.com/devcontainers/rust:1-1-bookworm{% else %}mcr.microsoft.com/devcontainers/base:ubuntu-22.04{% endif %}",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "redhat.vscode-yaml",
        "eamodio.gitlens"
      ]
    }
  },
  "postCreateCommand": "{% if language == 'python' %}{% if python_package_manager == 'uv' %}curl -LsSf https://astral.sh/uv/install.sh | sh && if [ -f requirements.txt ]; then uv pip install -r requirements.txt; fi{% elif python_package_manager == 'poetry' %}pip install poetry && if [ -f pyproject.toml ]; then poetry install; fi{% else %}python -m pip install --upgrade pip && if [ -f requirements.txt ]; then pip install -r requirements.txt; fi{% endif %}{% elif language == 'nodejs' %}{% if node_package_manager == 'pnpm' %}npm install -g pnpm && if [ -f package.json ]; then pnpm install; fi{% elif node_package_manager == 'yarn' %}npm install -g yarn && if [ -f package.json ]; then yarn install; fi{% else %}if [ -f package.json ]; then npm install; fi{% endif %}{% elif language == 'rust' %}rustup component add rustfmt clippy{% else %}echo 'Container initialized. Add language-specific install commands as needed.'{% endif %}",
  "forwardPorts": [3000, 8000, 8080]
}
