{
  "disabledServers": {
    "godot-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "gopeak"],
      "env": {
        "GOPEAK_TOOL_PROFILE": "compact",
        "GODOT_PATH": "${GODOT_PATH}"
      },
      "description": "GoPeak Godot MCP over stdio (disabled by default; move to servers to enable)"
    }
  }
}
