{
  "[gdscript]": {
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "files.associations": {
    "*.gd": "gdscript",
    "*.tscn": "ini",
    "*.tres": "ini"
  },
  "files.watcherExclude": {
    "**/.godot/**": true,
    "**/.godot4/**": true,
    "**/*.import": true
  },
  "search.exclude": {
    "**/.godot/**": true,
    "**/.godot4/**": true,
    "**/*.import": true
  }
}