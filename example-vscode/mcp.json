{
    "mcpServers": {
        "docs-mcp": {
            "type": "sse",
            "url": "http://docs.localhost/sse"
            // Fallback if .localhost DNS routing is unavailable: "http://localhost/docs/sse"
        },
        "sonarqube": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "sonarqube-mcp-server"
            ],
            "env": {
                "SONARQUBE_URL": "http://sonarqube.localhost",
                "SONARQUBE_TOKEN": "${SONARQUBE_TOKEN}"
            }
        }
    }
}